# Cấu hình AI — chọn MỘT nhà cung cấp (hoặc nhập trực tiếp trong giao diện app qua nút 🔑)

# 1) Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# 2) Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-5

# 3) Endpoint tùy chỉnh (OpenAI-compatible: Groq, OpenRouter, DeepSeek, dịch vụ bán lại API...)
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=https://api.dichvu.com/v1
# OPENAI_MODEL=gpt-4o-mini
